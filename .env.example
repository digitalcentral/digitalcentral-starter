# Convex backend (also set these in Convex dashboard → Settings → Environment Variables)
BETTER_AUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Leave empty for local dev; for production use your Convex deployment URL
CONVEX_DEPLOYMENT="http://localhost:3000"

# Next.js / Convex (from Convex dashboard after creating/linking project)
NEXT_PUBLIC_CONVEX_URL=""
NEXT_PUBLIC_CONVEX_SITE_URL=""
# Your app URL (localhost for dev; e.g. https://your-app.vercel.app for prod)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: for non-interactive deploy (CI/agent). From Convex dashboard → Settings → Deploy keys (production)
# CONVEX_DEPLOY_KEY="prod:your-deployment|eyJ..."
